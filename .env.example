# Copy to .env for local dev. Production → Vercel → Settings → Environment Variables.
# Never commit .env or real secrets to git.

# ── Public (safe in client bundle) ──────────────────────────────────────────

# Hostname used for redirects and site detection (no https://)
NEXT_PUBLIC_APP_HOST=portfolio.muscadine.io

# ── Server-only — set on Vercel (Production + Preview) ────────────────────────

# Home API base URL. When set, /api/* routes proxy to the mini PC.
# Local dev: http://127.0.0.1:3001
# Production: https://api-portfolio.muscadine.io
API_URL=https://api-portfolio.muscadine.io

# SECRET — must exactly match api-portfolio API_SECRET.
# Used to verify session cookies signed by the home API (middleware + /api/auth).
# Generate: openssl rand -base64 32
API_SECRET=your-secret-here-match-api-portfolio

# ── Optional — local dev without home API ─────────────────────────────────────
# Ignored in production when API_URL is set (login + data come from home API).

# Default tenant slug when no portfolio_tenant cookie (local only)
# DEV_TENANT=workspace

# Legacy single-user auth when API_URL is unset (not used with home API)
# PORTFOLIO_USERNAME=
# PORTFOLIO_PASSWORD=

# Fallback session signing secret when API_URL is unset (dev only)
# PORTFOLIO_AUTH_SECRET=

# ── Not used on portfolio (keep on api-portfolio / mini PC only) ──────────────
# ADMIN_SECRET, ADMIN_PASSWORD, FINNHUB_API_KEY, FINNHUB_WEBHOOK_SECRET
