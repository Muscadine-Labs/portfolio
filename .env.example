# Single app URL (no per-user subdomains). Override for local/staging:
# NEXT_PUBLIC_APP_HOST=portfolio.muscadine.io

# Internal workspace slug (must match api.portfolio DEV_TENANT / seed TENANT_USERS key):
DEV_TENANT=demo

# Home API — all portfolio data lives here (mini PC or production tunnel):
# API_URL=http://127.0.0.1:3001
# API_URL=https://api.portfolio.muscadine.io

# Optional: require username + password to access the app (both must be set)
# PORTFOLIO_USERNAME=
# PORTFOLIO_PASSWORD=
# Optional separate secret for session signing (defaults to PORTFOLIO_PASSWORD)
# PORTFOLIO_AUTH_SECRET=
